" =========================
" Plugins
" =========================
call plug#begin('~/.vim/plugged')

Plug 'morhetz/gruvbox'
Plug 'catppuccin/vim', { 'as': 'catppuccin' }
Plug 'arcticicestudio/nord-vim'
Plug 'joshdick/onedark.vim'
Plug 'sainnhe/everforest'
Plug 'sainnhe/gruvbox-material'
Plug 'rose-pine/vim'
Plug 'sainnhe/sonokai'
Plug 'sainnhe/edge'
Plug 'ghifarit53/tokyonight-vim'  " version vim de tokyonight (pas .nvim)

call plug#end()

" =========================
" Apparence
" =========================
set background=dark
silent! colorscheme catppuccin_mocha  " silent! evite l'erreur si plugin pas encore installe
set number                            " numeros de lignes
set cursorline                        " surligne la ligne actuelle
set termguicolors                     " true color si le terminal le supporte

" =========================
" Tabulation : 2 espaces
" =========================
set tabstop=2      " un tab = 2 espaces visuellement
set shiftwidth=2   " indentation avec >> et << = 2 espaces
set softtabstop=2  " tab en mode insertion = 2 espaces
set expandtab      " remplace les tabs par des espaces

" =========================
" Edition
" =========================
set showmatch    " montre brievement la parenthese correspondante
set nowrap       " pas de retour a la ligne automatique
set hidden       " permet de changer de buffer sans sauvegarder

" Partage le presse-papier avec le systeme
" "+y pour copier vers le systeme
" "+p pour coller depuis le systeme
set clipboard=unnamedplus

set mouse=a      " souris activee dans tous les modes
set splitright   " nouveau split vertical s'ouvre a droite
set splitbelow   " nouveau split horizontal s'ouvre en bas
